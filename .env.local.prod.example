# Director's Note — Production environment template
# Copy to .env.local.prod (gitignored via .env* rule) and fill in PROD values.
# Used by scripts that need prod DB access (seed-prod-academy, ad-hoc psql).
# Vercel Production Environment variables are set in Vercel dashboard, not here.

# ──── Supabase (PROD project — NOT dev) ────────────────────────────
# 출처: Supabase Dashboard → directors-note-prod 프로젝트 → Settings → API
# dev 의 kyizppeuvalqjtnhyqgf 와 반드시 다른 값이어야 함.
NEXT_PUBLIC_SUPABASE_URL=https://<prod-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 출처: directors-note-prod → Settings → Database → Connection string (Session pooler).
# 비밀번호는 prod 프로젝트 생성 시 따로 기록해 둔 값.
DATABASE_URL=postgresql://postgres.<prod-ref>:[PWD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# ──── Korean LLM ───────────────────────────────────────────────────
# Prod 전용 OpenAI 키 권장 (dev 키와 분리해 사용량/요금 추적).
OPENAI_API_KEY=sk-...

# ──── Kakao OAuth ──────────────────────────────────────────────────
# C3 결정: 단일 앱 multi Redirect URI. dev 와 동일한 값.
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=

# ──── App URL ──────────────────────────────────────────────────────
# C2 결정: *.vercel.app subdomain. Vercel 첫 deploy 후 실제 부여된 URL 로 갱신.
NEXT_PUBLIC_APP_URL=https://<project-slug>.vercel.app

# ──── Vertex AI ────────────────────────────────────────────────────
# V1 파일럿은 단일 GCP project — dev 와 동일.
GOOGLE_VERTEX_PROJECT_ID=directors-note
GOOGLE_VERTEX_LOCATION=asia-northeast1
GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account",...}'
GCS_VIDEO_BUCKET=directors-note-video-staging-7891

# ──── Cryptography ─────────────────────────────────────────────────
# NEW 값 필수 — dev pepper 재사용 금지. share-link 토큰 hash 가 환경별로 다르도록.
# 생성: openssl rand -hex 32
SHARE_LINK_PEPPER=

# ──── Cron ─────────────────────────────────────────────────────────
# Vercel Cron 인증 시크릿 (생성: openssl rand -hex 32). dev 와 다른 값 권장.
# 실제 prod 런타임 값은 Vercel 대시보드 Production env 에 설정한다(여기 파일은
# prod DB 접근 스크립트용). /api/cron/sweep-assignments 가 Bearer 로 검증.
CRON_SECRET=

# ──── Feature flags ────────────────────────────────────────────────
# Vertex 코드 경로 미검증 — 검증 후 (P0 smoke test + reference 영상 시드 후) true.
FEATURE_AI_VIDEO_ANALYSIS=false
