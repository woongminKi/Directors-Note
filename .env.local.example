# ──── Supabase ────────────────────────────────────────────────────
# 출처: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Drizzle direct connection (postgres.js)
# 출처: Supabase Dashboard → Settings → Database → Connection string (Session pooler)
DATABASE_URL=postgresql://postgres.xxx:[PWD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# ──── Korean LLM ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# v2 후보 (지금은 비워둠):
# HYPERCLOVA_API_KEY=
# UPSTAGE_API_KEY=

# ──── Vertex AI (PIPA 의견 후 채울 것) ─────────────────────────────
GOOGLE_VERTEX_PROJECT_ID=your-gcp-project
GOOGLE_VERTEX_LOCATION=asia-northeast1
GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account",...}'

# ──── Cryptography ─────────────────────────────────────────────────
# 32-byte hex (생성: openssl rand -hex 32). 부모 share-link sha256 pepper.
SHARE_LINK_PEPPER=

# ──── Feature flags ────────────────────────────────────────────────
# D6/D14: false 면 Approach-A 코치 불릿 폼. PIPA 의견 받은 후 true 로 변경.
FEATURE_AI_VIDEO_ANALYSIS=false
