# ──── Supabase ────────────────────────────────────────────────────
# 출처: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Drizzle direct connection (postgres.js)
# 출처: Supabase Dashboard → Settings → Database → Connection string (Session pooler)
DATABASE_URL=postgresql://postgres.xxx:[PWD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# ──── Korean LLM ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# v2 후보 (지금은 비워둠):
# HYPERCLOVA_API_KEY=
# UPSTAGE_API_KEY=

# ──── Kakao OAuth ──────────────────────────────────────────────────
# 출처: Kakao Developers → Your App → 카카오 로그인 → 보안
# 자세한 셋업: docs/oauth-handoff.md
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=

# ──── App URL ──────────────────────────────────────────────────────
# Dev: http://localhost:3000. Prod 배포 시 production 도메인으로 변경.
# `/auth/callback` redirect 도 이 도메인 기준으로 구성됨.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──── Vertex AI ────────────────────────────────────────────────────
# 셋업 가이드: docs/oauth-handoff.md 또는 세션 로그 (GCP/Vertex 셋업 9단계)
# 서비스 계정 권한: Vertex AI User (Agent Platform 사용자) + Storage 객체 관리자
# Vertex multimodalembedding 지원 리전: asia-northeast1 (도쿄), us-central1, europe-west4
GOOGLE_VERTEX_PROJECT_ID=your-gcp-project
GOOGLE_VERTEX_LOCATION=asia-northeast1
GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account",...}'
# GCS bucket for staging videos before Vertex multimodal embedding analysis.
# 1-day lifecycle delete recommended (비용 절감).
GCS_VIDEO_BUCKET=directors-note-video-staging-XXXX

# ──── Cryptography ─────────────────────────────────────────────────
# 32-byte hex (생성: openssl rand -hex 32). 부모 share-link sha256 pepper.
SHARE_LINK_PEPPER=

# ──── Feature flags ────────────────────────────────────────────────
# D6/D14: false 면 Approach-A 코치 불릿 폼. PIPA 의견 받은 후 true 로 변경.
FEATURE_AI_VIDEO_ANALYSIS=false
